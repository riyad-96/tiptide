{
  "name": "tiptide",
  "version": "0.0.0",
  "description": "A text editor built on top of tiptap text editor components.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc -b && vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "cs": "changeset"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript-eslint": "^8.52.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "author": "Riyad",
  "keywords": [
    "text",
    "editor"
  ],
  "homepage": "https://github.com/riyad-96/tiptide#readme",
  "bugs": {
    "url": "https://github.com/riyad-96/tiptide/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riyad-96/tiptide.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.1.1"
}
